<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KartPit — Pitstop Timer</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes neon-glow {
      0%, 100% { text-shadow: 0 0 10px rgba(232,0,45,0.5); }
      50% { text-shadow: 0 0 20px rgba(232,0,45,0.8); }
    }

    @keyframes pulse-scale {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.02); }
    }

    .section-title::before {
      animation: neon-glow 2s ease-in-out infinite;
    }

    .page-header { animation: fadeInDown 0.6s ease-out; }
    .card { animation: fadeInUp 0.6s ease-out; transition: all 0.3s ease; }
    .card:hover { box-shadow: 0 8px 32px rgba(232,0,45,0.15); }

    .timer-display {
      animation: fadeInUp 0.6s ease-out;
      font-variant-numeric: tabular-nums;
    }

    .timer-controls {
      animation: fadeInUp 0.7s ease-out 0.1s both;
    }

    .stat-grid {
      animation: fadeInUp 0.7s ease-out 0.2s both;
    }

    .card-value {
      transition: transform 0.3s ease, color 0.3s ease;
    }

    .card:hover .card-value {
      transform: scale(1.05);
      color: var(--red);
    }

    #timer-display {
      animation: pulse-scale 1s ease-in-out 3s;
    }

    .btn.active {
      animation: pulse-scale 0.6s ease-out;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Navigation -->
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="nav-logo">
          <span class="flag">🏁</span>KART<span>PIT</span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/tracks">Tracks</a>
          <a href="/pitstop" class="active">Pitstop</a>
          <a href="/agenda">Agenda</a>
          <a href="/checklist">Checklist</a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main class="page-content">
      <div class="page-header">
        <div class="eyebrow">Race Tools</div>
        <h1>PITSTOP TIMER</h1>
        <p class="subtitle">Measure & log your pitstop durations. Space = start/stop &nbsp;|&nbsp; R = reset</p>
      </div>

      <div class="card" style="text-align:center;margin-bottom:24px">
        <div id="timer-display" class="timer-display">00:00.00</div>

        <div style="display:flex;align-items:center;gap:12px;justify-content:center;margin-bottom:24px">
          <label class="form-label" for="target-time">Target (sec):</label>
          <input type="number" id="target-time" placeholder="e.g. 8" step="0.1" min="0" style="width:120px;text-align:center" />
        </div>

        <div class="timer-controls">
          <button id="btn-start" class="btn btn-red btn-lg">▶ START</button>
          <button id="btn-stop"  class="btn btn-outline btn-lg" disabled>⏸ STOP</button>
          <button id="btn-reset" class="btn btn-ghost btn-lg">↺ RESET</button>
          <button id="btn-save"  class="btn btn-outline btn-lg" disabled>💾 SAVE STOP</button>
        </div>
      </div>

      <div class="stat-grid" style="margin-bottom:32px">
        <div class="card card-green">
          <div class="card-title">Best Stop</div>
          <div class="card-value" id="stat-best" style="font-size:32px">–</div>
        </div>
        <div class="card card-yellow">
          <div class="card-title">Average</div>
          <div class="card-value" id="stat-avg" style="font-size:32px">–</div>
        </div>
        <div class="card card-red">
          <div class="card-title">Worst Stop</div>
          <div class="card-value" id="stat-worst" style="font-size:32px">–</div>
        </div>
        <div class="card card-blue">
          <div class="card-title">Total Stops</div>
          <div class="card-value" id="stat-count" style="font-size:32px">0</div>
        </div>
      </div>

      <div class="section-header">
        <h2 class="section-title">Stop History</h2>
      </div>
      <div id="stop-history" class="timer-history"></div>

      <div id="save-modal" class="modal-overlay">
        <div class="modal">
          <div class="modal-title">💾 Save Pitstop</div>
          <div class="form-group" style="margin-bottom:16px">
            <label class="form-label">Label</label>
            <input type="text" id="stop-label" placeholder="e.g. Race 1 – Lap 8 stop" />
          </div>
          <div class="form-group" style="margin-bottom:24px">
            <label class="form-label">Notes</label>
            <textarea id="stop-notes" rows="3" placeholder="Any notes about this stop…" style="resize:vertical"></textarea>
          </div>
          <div style="display:flex;gap:12px">
            <button id="btn-confirm-save" class="btn btn-red">Save</button>
            <button class="btn btn-outline" data-close-modal>Cancel</button>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
      KartPit &mdash; Amateur Karting Race Manager &mdash; Built with 🏎️
    </footer>
  </div>

  <!-- Toast Container -->
  <div id="toast-container"></div>

  <script src="/main.js"></script>
  <script src="/timer.js"></script>
</body>
</html>
