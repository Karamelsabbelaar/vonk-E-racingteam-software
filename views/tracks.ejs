<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KartPit — Tracks</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes neon-glow {
      0%, 100% { text-shadow: 0 0 10px rgba(232,0,45,0.5); }
      50% { text-shadow: 0 0 20px rgba(232,0,45,0.8); }
    }

    .section-title::before {
      animation: neon-glow 2s ease-in-out infinite;
    }

    .page-header { animation: fadeInUp 0.6s ease-out; }
    .card { animation: fadeInUp 0.6s ease-out; transition: all 0.3s ease; }
    .card:hover { box-shadow: 0 8px 32px rgba(232,0,45,0.15); transform: translateY(-2px); }

    .track-card {
      animation: fadeInUp 0.6s ease-out both;
      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .track-card:nth-child(1) { animation-delay: 0.1s; }
    .track-card:nth-child(2) { animation-delay: 0.2s; }
    .track-card:nth-child(3) { animation-delay: 0.3s; }
    .track-card:nth-child(n+4) { animation-delay: 0.4s; }

    .track-card:hover {
      transform: translateY(-8px);
      border-color: var(--red);
      box-shadow: 0 12px 32px rgba(232,0,45,0.25);
    }

    .track-name {
      transition: color 0.3s ease;
    }

    .track-card:hover .track-name {
      color: var(--red);
    }

    .track-stat-value {
      transition: transform 0.3s ease;
    }

    .track-card:hover .track-stat-value {
      transform: scale(1.1);
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Navigation -->
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="nav-logo">
          <span class="flag">🏁</span>KART<span>PIT</span>
        </a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/tracks" class="active">Tracks</a>
          <a href="/pitstop">Pitstop</a>
          <a href="/agenda">Agenda</a>
          <a href="/checklist">Checklist</a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main class="page-content">
      <div class="page-header">
        <div class="eyebrow">Circuit Database</div>
        <h1>TRACKS</h1>
        <p class="subtitle">Karting circuits with layout notes and lap benchmarks</p>
      </div>

      <div class="card" style="margin-bottom:40px">
        <h3 class="section-title" style="margin-bottom:16px">Add Track</h3>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Track Name</label>
            <input type="text" id="tr-name" placeholder="e.g. Rye House Kart Circuit" />
          </div>
          <div class="form-group">
            <label class="form-label">Location</label>
            <input type="text" id="tr-loc" placeholder="City, Country" />
          </div>
          <div class="form-group" style="max-width:130px">
            <label class="form-label">Length (m)</label>
            <input type="number" id="tr-len" placeholder="950" />
          </div>
          <div class="form-group" style="max-width:100px">
            <label class="form-label">Turns</label>
            <input type="number" id="tr-turns" placeholder="12" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group" style="max-width:140px">
            <label class="form-label">Best Lap</label>
            <input type="text" id="tr-lap" placeholder="e.g. 47.2s" />
          </div>
          <div class="form-group" style="max-width:160px">
            <label class="form-label">Type</label>
            <select id="tr-type">
              <option value="outdoor">Outdoor</option>
              <option value="indoor">Indoor</option>
              <option value="indoor/outdoor">Indoor/Outdoor</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Notes</label>
            <input type="text" id="tr-notes" placeholder="Corner tips, surface notes…" />
          </div>
          <div style="display:flex;align-items:flex-end">
            <button onclick="addTrack()" class="btn btn-red">+ Add</button>
          </div>
        </div>
      </div>

      <div class="tracks-grid" id="tracks-grid">
        <% tracks.forEach((t, index) => { %>
        <div class="track-card">
          <div class="track-header">
            <div>
              <div class="track-name"><%= t.name %></div>
              <div style="font-size:13px;color:var(--text3);margin-top:2px">📍 <%= t.location %></div>
            </div>
            <% 
              let typeBadge = 'badge-yellow';
              if (t.type === 'indoor') typeBadge = 'badge-blue';
              else if (t.type === 'outdoor') typeBadge = 'badge-green';
            %>
            <span class="badge <%= typeBadge %>"><%= t.type %></span>
          </div>
          <div class="track-body">
            <div class="track-stat">
              <span class="track-stat-label">Length</span>
              <span class="track-stat-value"><%= t.length_m %>m</span>
            </div>
            <div class="track-stat">
              <span class="track-stat-label">Turns</span>
              <span class="track-stat-value"><%= t.turns %></span>
            </div>
            <div class="track-stat">
              <span class="track-stat-label">Best Lap</span>
              <span class="track-stat-value" style="color:var(--yellow)"><%= t.best_lap %></span>
            </div>
            <% if (t.notes) { %>
            <div class="track-notes">💡 <%= t.notes %></div>
            <% } %>
          </div>
        </div>
        <% }); %>
      </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
      KartPit &mdash; Amateur Karting Race Manager &mdash; Built with 🏎️
    </footer>
  </div>

  <!-- Toast Container -->
  <div id="toast-container"></div>

  <script src="/main.js"></script>
  <script>
    async function addTrack() {
      const get = id => document.getElementById(id).value;
      const name = get('tr-name').trim();
      if (!name) { Toast.show('Track name required', 'error'); return; }
      const payload = {
        name,
        location: get('tr-loc'),
        length_m: parseInt(get('tr-len')) || 0,
        turns:    parseInt(get('tr-turns')) || 0,
        best_lap: get('tr-lap') || '–',
        type:     get('tr-type'),
        notes:    get('tr-notes')
      };
      const res = await API.post('/api/tracks/add', payload);
      if (res.ok) {
        Toast.show('Track added', 'success');
        setTimeout(() => location.reload(), 800);
      }
    }
  </script>
</body>
</html>
