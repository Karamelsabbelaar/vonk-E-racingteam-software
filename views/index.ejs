<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KartPit — Home</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    /* ── Animations ────────────────────────────────────────────── */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideInLeft {
      from {
        opacity: 0;
        transform: translateX(-30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes neon-glow {
      0%, 100% { text-shadow: 0 0 10px rgba(232,0,45,0.5); }
      50% { text-shadow: 0 0 20px rgba(232,0,45,0.8); }
    }

    @keyframes shimmer {
      0% { background-position: -1000px 0; }
      100% { background-position: 1000px 0; }
    }

    /* ── Animation Classes ─────────────────────────────────────── */
    .hero {
      animation: fadeInDown 0.8s ease-out;
    }

    .hero-text {
      animation: slideInLeft 0.8s ease-out 0.1s both;
    }

    .hero-visual {
      animation: slideInRight 0.8s ease-out 0.1s both;
    }

    .hero-text h1 .red {
      animation: neon-glow 2s ease-in-out infinite;
    }

    .section-title::before {
      animation: neon-glow 2s ease-in-out infinite;
    }

    .quicknav-card {
      animation: fadeInUp 0.6s ease-out both;
      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
      overflow: hidden;
    }

    .quicknav-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
      animation: shimmer 3s infinite;
    }

    .quicknav-card:hover {
      transform: translateY(-8px);
      border-color: var(--red);
      box-shadow: 0 12px 24px rgba(232,0,45,0.2);
    }

    .quicknav-card:nth-child(1) { animation-delay: 0.1s; }
    .quicknav-card:nth-child(2) { animation-delay: 0.2s; }
    .quicknav-card:nth-child(3) { animation-delay: 0.3s; }
    .quicknav-card:nth-child(4) { animation-delay: 0.4s; }

    .quicknav-icon {
      font-size: 40px;
      display: inline-block;
      transition: transform 0.3s ease;
    }

    .quicknav-card:hover .quicknav-icon {
      transform: scale(1.2) rotate(5deg);
    }

    .card {
      animation: fadeInUp 0.6s ease-out;
      transition: all 0.3s ease;
    }

    .card:hover {
      box-shadow: 0 8px 32px rgba(232,0,45,0.15);
      transform: translateY(-2px);
    }

    .card-value {
      transition: transform 0.3s ease, color 0.3s ease;
    }

    .card:hover .card-value {
      transform: scale(1.05);
      color: var(--red);
    }

    .data-table tbody tr {
      animation: fadeInUp 0.5s ease-out;
      transition: all 0.3s ease;
    }

    .data-table tbody tr:hover {
      background: rgba(232,0,45,0.05) !important;
    }

    .btn {
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .btn::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 0;
      height: 0;
      background: rgba(255,255,255,0.3);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      transition: width 0.6s, height 0.6s;
    }

    .btn:active::before {
      width: 300px;
      height: 300px;
    }

    .section-header {
      animation: fadeInUp 0.6s ease-out;
    }

    /* ── Responsive ──────────────────────────────────────────── */
    @media (max-width: 768px) {
      .hero-text h1 {
        font-size: 56px;
      }

      .quicknav-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .stat-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 480px) {
      .quicknav-grid {
        grid-template-columns: 1fr;
      }

      .stat-grid {
        grid-template-columns: 1fr;
      }

      .hero-actions {
        flex-direction: column;
      }

      .btn-lg {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Navigation -->
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="nav-logo">
          <span class="flag">🏁</span>KART<span>PIT</span>
        </a>
        <div class="nav-links">
          <a href="/" class="active">Home</a>
          <a href="/tracks">Tracks</a>
          <a href="/pitstop">Pitstop</a>
          <a href="/agenda">Agenda</a>
          <a href="/checklist">Checklist</a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main class="page-content">
      <!-- Hero -->
      <section class="hero">
        <div class="hero-grid">
          <div class="hero-text">
            <h1>RACE<br><span class="red">READY.</span></h1>
            <p>Your complete amateur karting race day manager. Track info, pitstop timers, race agenda, and pre-race checklists — all in one paddock tool.</p>
            <div class="hero-actions">
              <a href="/pitstop" class="btn btn-red btn-lg">⏱ Pitstop Timer</a>
              <a href="/checklist" class="btn btn-outline btn-lg">☑ Checklist</a>
            </div>
          </div>
          <div class="hero-visual">
            <div class="kart-icon-big">🏎️</div>
            <div class="hero-stats">
              <div class="card card-red">
                <div class="card-title">Tracks Saved</div>
                <div class="card-value"><%= tracks.length %></div>
              </div>
              <div class="card card-yellow">
                <div class="card-title">Pitstops Logged</div>
                <div class="card-value"><%= pitstops.length %></div>
              </div>
              <div class="card card-green">
                <div class="card-title">Events Today</div>
                <div class="card-value"><%= agenda.length %></div>
              </div>
              <div class="card card-blue">
                <div class="card-title">Status</div>
                <div class="card-value" style="font-size:22px;padding-top:4px">Race Day 🏁</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Quick Nav -->
      <div class="section-header">
        <h2 class="section-title">Quick Access</h2>
      </div>
      <div class="quicknav-grid">
        <a href="/tracks" class="quicknav-card">
          <div class="quicknav-icon">🗺️</div>
          <div class="quicknav-label">Tracks</div>
          <div class="quicknav-sub">Circuit info & notes</div>
        </a>
        <a href="/pitstop" class="quicknav-card">
          <div class="quicknav-icon">⏱️</div>
          <div class="quicknav-label">Pitstop Timer</div>
          <div class="quicknav-sub">Live stopwatch & history</div>
        </a>
        <a href="/agenda" class="quicknav-card">
          <div class="quicknav-icon">📋</div>
          <div class="quicknav-label">Race Agenda</div>
          <div class="quicknav-sub">Schedule & sessions</div>
        </a>
        <a href="/checklist" class="quicknav-card">
          <div class="quicknav-icon">✅</div>
          <div class="quicknav-label">Checklist</div>
          <div class="quicknav-sub">Kart & team readiness</div>
        </a>
      </div>

      <!-- Recent Agenda -->
      <div class="section-header" style="margin-top:12px">
        <h2 class="section-title">Today's Schedule</h2>
        <a href="/agenda" class="btn btn-ghost btn-sm">View all →</a>
      </div>
      <div class="card" style="padding:0;overflow:hidden">
        <table class="data-table">
          <thead>
            <tr>
              <th>Time</th>
              <th>Event</th>
              <th>Type</th>
            </tr>
          </thead>
          <tbody>
            <% 
              agenda.slice(0, 5).forEach((item, index) => { 
                let badgeClass = 'badge-gray';
                if (item.type === 'race') badgeClass = 'badge-red';
                else if (item.type === 'qualifying') badgeClass = 'badge-yellow';
                else if (item.type === 'session') badgeClass = 'badge-blue';
                else if (item.type === 'pitstop') badgeClass = 'badge-green';
            %>
            <tr style="animation-delay: <%= (index * 0.05) %>s;">
              <td style="font-family:var(--font-display);font-size:18px;color:var(--text2)"><%= item.time %></td>
              <td><%= item.event %></td>
              <td>
                <span class="badge <%= badgeClass %>"><%= item.type %></span>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
      KartPit &mdash; Amateur Karting Race Manager &mdash; Built with 🏎️
    </footer>
  </div>

  <!-- Toast Container -->
  <div id="toast-container"></div>

  <script src="/main.js"></script>
</body>
</html>
